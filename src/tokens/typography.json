{
  "text": {
    "xs":  { "$value": "0.75rem",  "$type": "dimension" },
    "sm":  { "$value": "0.875rem", "$type": "dimension" },
    "base":{ "$value": "1rem",     "$type": "dimension" },
    "lg":  { "$value": "1.125rem", "$type": "dimension" },
    "xl":  { "$value": "1.25rem",  "$type": "dimension" },
    "2xl": { "$value": "1.5rem",   "$type": "dimension" },
    "3xl": { "$value": "1.875rem", "$type": "dimension" },
    "4xl": { "$value": "2.25rem",  "$type": "dimension" },
    "5xl": { "$value": "3rem",     "$type": "dimension" },
    "6xl": { "$value": "3.75rem",  "$type": "dimension" }
  },
  "line-height": {
    "xs":  { "$value": "1rem",    "$type": "dimension" },
    "sm":  { "$value": "1.25rem", "$type": "dimension" },
    "base":{ "$value": "1.5rem",  "$type": "dimension" },
    "lg":  { "$value": "1.75rem", "$type": "dimension" },
    "xl":  { "$value": "1.75rem", "$type": "dimension" },
    "2xl": { "$value": "2rem",    "$type": "dimension" },
    "3xl": { "$value": "2.25rem", "$type": "dimension" },
    "4xl": { "$value": "2.5rem",  "$type": "dimension" },
    "5xl": { "$value": "3.5rem",  "$type": "dimension" },
    "6xl": { "$value": "4rem",    "$type": "dimension" }
  },
  "font": {
    "sans": { "$value": "'Manrope', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif", "$type": "fontFamily" },
    "mono": { "$value": "'Fira Code', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace", "$type": "fontFamily" },
    "weight": {
      "light":      { "$value": "300", "$type": "fontWeight" },
      "regular":    { "$value": "400", "$type": "fontWeight" },
      "medium":     { "$value": "500", "$type": "fontWeight" },
      "semibold":   { "$value": "600", "$type": "fontWeight" },
      "bold":       { "$value": "700", "$type": "fontWeight" },
      "extrabold":  { "$value": "800", "$type": "fontWeight" }
    }
  }
}
